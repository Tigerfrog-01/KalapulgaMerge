@using KalapulgaMerge.Models.Shop
@model IEnumerable<ShopItemViewModel>
@{
    ViewData["Title"] = "Pood";
    var items = Model?.ToList() ?? new List<ShopItemViewModel>();
    var groups = items.GroupBy(x => string.IsNullOrWhiteSpace(x.Type) ? "Muu" : x.Type).ToList();

    string GetImageUrl(string? filePath)
    {
        if (string.IsNullOrWhiteSpace(filePath))
        {
            return "";
        }

        var normalized = filePath.Replace("\\", "/").TrimStart('/');

        if (normalized.StartsWith("lib/", StringComparison.OrdinalIgnoreCase) ||
            normalized.StartsWith("uploads/", StringComparison.OrdinalIgnoreCase) ||
            normalized.StartsWith("multipleFileUpload/", StringComparison.OrdinalIgnoreCase))
        {
            return Url.Content("~/" + normalized);
        }

        return Url.Content("~/multipleFileUpload/" + normalized);
    }
}

<section class="shop-page">
    <div class="shop-toolbar">
        <div>
            <span class="shop-eyebrow">Merge inventory</span>
            <h1>Pood</h1>
        </div>
        <a asp-action="Create" class="btn btn-primary">Loo uus ese</a>
    </div>

    @if (ViewBag.ShopNotice != null)
    {
        <div class="shop-notice">@ViewBag.ShopNotice</div>
    }

    <div class="shop-controls">
        <div class="btn-group shop-filter-group" role="group" aria-label="Shop filters">
            <button type="button" class="btn btn-outline-secondary active" onclick="filterShop('All', this)">Kõik</button>
            @foreach (var type in groups.Select(x => x.Key).Distinct())
            {
                <button type="button" class="btn btn-outline-secondary" onclick="filterShop('@type', this)">@type</button>
            }
        </div>

        <select class="form-select shop-sort" onchange="sortAllGroups(this.value)">
            <option value="default">Sorteeri: Tavaline</option>
            <option value="low">Hind: Odavamad enne</option>
            <option value="high">Hind: Kallimad enne</option>
        </select>
    </div>

    @if (!groups.Any())
    {
        <div class="shop-empty">
            <h2>Pood on tühi</h2>
            <p>Lisa esimene ese, et kataloog siia ilmuks.</p>
        </div>
    }

    @foreach (var group in groups)
    {
        <div class="shop-group-section" data-group-type="@group.Key">
            <h2 class="shop-group-title">@group.Key</h2>
            <div class="items-grid shop-grid">
                @foreach (var item in group)
                {
                    var imagePath = item.Images?.FirstOrDefault()?.FilePath;

                    <article class="shop-card shop-item-card" data-price="@item.Price.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)">
                        <div class="shop-card-image">
                            @if (!string.IsNullOrWhiteSpace(imagePath))
                            {
                                <img src="@GetImageUrl(imagePath)" alt="@item.Name">
                            }
                            else
                            {
                                <span>Pilt puudub</span>
                            }
                        </div>

                        <div class="shop-card-body">
                            <h3>@item.Name</h3>
                            <p>@item.Description</p>
                        </div>

                        <div class="shop-card-footer">
                            <strong>@item.Price münti</strong>
                            <a asp-action="Details" asp-route-id="@item.Id" class="shop-details-link">Vaata lähemalt</a>

                            @if (item.Id > 0)
                            {
                                <div class="shop-admin-actions">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">Muuda</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm">Kustuta</a>
                                </div>
                            }
                            else
                            {
                                <span class="shop-demo-label">Vaikimisi ese</span>
                            }
                        </div>
                    </article>
                }
            </div>
        </div>
    }
</section>

@section Scripts {
    <script>
        function filterShop(type, btn) {
            const buttons = document.querySelectorAll('.shop-filter-group .btn');
            buttons.forEach(b => b.classList.remove('active', 'btn-secondary', 'text-white'));
            buttons.forEach(b => b.classList.add('btn-outline-secondary'));

            btn.classList.add('active', 'btn-secondary', 'text-white');
            btn.classList.remove('btn-outline-secondary');

            const sections = document.querySelectorAll('.shop-group-section');
            sections.forEach(section => {
                if (type === 'All' || section.getAttribute('data-group-type') === type) {
                    section.style.display = 'block';
                } else {
                    section.style.display = 'none';
                }
            });
        }

        function sortAllGroups(order) {
            if (order === "default") return;

            const grids = document.querySelectorAll('.items-grid');

            grids.forEach(grid => {
                const cards = Array.from(grid.querySelectorAll('.shop-item-card'));

                cards.sort((a, b) => {
                    const priceA = parseFloat(a.getAttribute('data-price'));
                    const priceB = parseFloat(b.getAttribute('data-price'));

                    return order === 'low' ? priceA - priceB : priceB - priceA;
                });

                grid.innerHTML = "";
                cards.forEach(card => grid.appendChild(card));
            });
        }
    </script>
}
