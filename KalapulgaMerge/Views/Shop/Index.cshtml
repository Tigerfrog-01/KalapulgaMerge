@using KalapulgaMerge.Models.Shop
@model IEnumerable<ShopItemViewModel>
@{
    ViewData["Title"] = "Pood";
    var groups = Model.GroupBy(x => x.Type);
}

<p>
    <a asp-action="Create" class="btn btn-primary">Loo uus Ese</a>
</p>

<div style="max-width: 900px; margin: auto; font-family: sans-serif;">
    @foreach (var group in groups)
    {
        <h2 style="border-bottom: 1px solid #ddd; margin-top: 2rem;">@group.Key</h2>
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 1.5rem; margin-bottom: 2rem;">
            @foreach (var item in group)
            {
                <div class="card" style="border: 1px solid #eee; padding: 1rem; border-radius: 8px; text-align: center; box-shadow: 0 2px 5px rgba(0,0,0,0.05);">

                    <div style="width: 100%; aspect-ratio: 1; display: flex; align-items: center; justify-content: center; background: #fcfcfc; border-radius: 4px;">
                        @if (item.Images != null && item.Images.Any())
                        {
                            <img src="~/multipleFileUpload/@item.Images.FirstOrDefault()?.FilePath"
                                 style="max-width: 100%; max-height: 100%; object-fit: contain;"
                                 alt="@item.Name">
                        }
                        else
                        {
                            <span style="color: #ccc; font-size: 0.8rem;">Pilt puudub</span>
                        }
                    </div>

                    <h3 style="font-size: 1rem; margin: 0.8rem 0 0.3rem 0;">@item.Name</h3>
                    <p style="font-weight: bold; color: #e67e22; margin-bottom: 0.8rem;">@item.Price münti</p>

                    <a asp-action="Details" asp-route-id="@item.Id"
                       style="display: block; width: 100%; text-decoration: none; background: #3b82f6; color: white; padding: 8px; border-radius: 4px; font-size: 0.9rem;">
                        Vaata lähemalt
                    </a>
                </div>
            }
        </div>
    }
</div>