@{
    ViewData["Title"] = "Avaleht";
}

<section class="home-hub">
    <div class="home-title-block">
        <span class="home-eyebrow">Arcade hub</span>
        <h1>Kalapulga Merge</h1>
    </div>

    <div class="home-action-grid">
        <a asp-action="Index" asp-controller="Merge" class="home-action home-action-primary">
            <span class="home-action-mark">🎮</span>
            <span>Play Merge</span>
        </a>
        <a asp-action="Index" asp-controller="Shop" class="home-action">
            <span class="home-action-mark">🛒</span>
            <span>Pood</span>
        </a>
        <a asp-action="Leaderboard" asp-controller="Leaderboard" class="home-action">
            <span class="home-action-mark">🏆</span>
            <span>Leaderboard</span>
        </a>
        <a asp-action="Index" asp-controller="Game" class="home-action">
            <span class="home-action-mark">🪲</span>
            <span>Game</span>
        </a>
    </div>
</section>
