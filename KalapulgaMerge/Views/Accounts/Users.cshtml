@model IEnumerable<KalapulgaMerge.Core.Domain.UserAccount>
@{
    ViewData["Title"] = "Users";
}

<section class="admin-users-page">
    <div class="admin-users-header">
        <div>
            <span class="shop-eyebrow">Admin</span>
            <h1>Users</h1>
        </div>
        <form asp-action="Users" method="get" class="admin-search-form">
            <input type="text" name="search" value="@ViewBag.Search" placeholder="Filter by name" />
            <button type="submit" class="btn btn-primary">Filter</button>
        </form>
    </div>

    @if (ViewBag.Error != null)
    {
        <p class="text-danger">@ViewBag.Error</p>
    }

    <div class="admin-users-table">
        <table>
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Created</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>@user.Name</td>
                        <td>@user.Email</td>
                        <td>@user.CreatedAt.ToString("yyyy-MM-dd")</td>
                        <td>
                            <div class="admin-table-actions">
                                <a asp-action="EditUser" asp-route-id="@user.Id" class="btn btn-outline-primary btn-sm">Update</a>
                                <form asp-action="DeleteUser" asp-route-id="@user.Id" method="post" class="admin-row-form">
                                    <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
