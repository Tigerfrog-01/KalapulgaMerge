@model KalapulgaMerge.Core.Domain.UserAccount
@{
    ViewData["Title"] = "Update user";
}

<section class="admin-edit-page">
    <div>
        <span class="shop-eyebrow">Admin</span>
        <h1>Update user</h1>
    </div>

    @if (ViewBag.Error != null)
    {
        <p class="text-danger">@ViewBag.Error</p>
    }

    <form asp-action="EditUser" asp-route-id="@Model.Id" method="post" class="admin-edit-form">
        <label>Name</label>
        <input name="name" type="text" value="@Model.Name" required />

        <label>Email</label>
        <input name="email" type="email" value="@Model.Email" required />

        <label>New password</label>
        <input name="password" type="password" placeholder="Leave empty to keep current password" />

        <div class="admin-edit-actions">
            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-action="Users" class="btn btn-outline-secondary">Back</a>
        </div>
    </form>
</section>