<!DOCTYPE html>
<html>
@{
    var mergePlayerName = ViewBag.PlayerName as string ?? "Player";
}
<head>
    <style>
        :root {
            --bg: #f7ecd9;
            --ink: #1f2529;
            --panel: rgba(255, 250, 240, 0.9);
            --panel-strong: #fffaf0;
            --board: #0f8f8a;
            --board-border: #0b4f52;
            --board-shadow: rgba(20, 38, 36, 0.28);
            --tile-text: #1f2529;
            --tile-glow: #fff7df;
            --btn-main: #ef6f4f;
            --btn-shadow: #a93f2d;
            --lb-bg: rgba(255, 250, 240, 0.92);
            --lb-text: #0b5d60;
            --accent: #f5b84b;
            --line: rgba(31, 37, 41, 0.14);
        }

        body.theme-ocean {
            --bg: #dff7f1;
            --ink: #113238;
            --panel: rgba(239, 255, 250, 0.92);
            --panel-strong: #f7fffc;
            --board: #0c7f9f;
            --board-border: #075063;
            --tile-text: #ffffff;
            --tile-glow: #073642;
            --btn-main: #22b8cf;
            --btn-shadow: #087f8c;
            --lb-bg: rgba(239, 255, 250, 0.94);
            --lb-text: #075063;
            --accent: #f2c94c;
        }

        body.theme-neon {
            --bg: #101116;
            --ink: #f5fff8;
            --panel: rgba(20, 23, 29, 0.9);
            --panel-strong: #171a21;
            --board: #20242d;
            --board-border: #00d084;
            --tile-text: #7dffb6;
            --tile-glow: #0b1013;
            --btn-main: #ff4f8b;
            --btn-shadow: #6f1749;
            --lb-bg: rgba(18, 21, 27, 0.96);
            --lb-text: #7dffb6;
            --accent: #ffde59;
            --line: rgba(125, 255, 182, 0.22);
        }

        body {
            min-height: 100vh;
            margin: 0;
            padding: 0;
            color: var(--ink);
            background:
                linear-gradient(135deg, rgba(15, 143, 138, 0.16) 0 22%, transparent 22% 100%),
                linear-gradient(315deg, rgba(239, 111, 79, 0.13) 0 18%, transparent 18% 100%),
                repeating-linear-gradient(0deg, rgba(31, 37, 41, 0.035) 0 1px, transparent 1px 34px),
                var(--bg);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        .merge-game-page {
            width: min(980px, calc(100vw - 24px));
            margin: 34px auto 58px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 24px;
        }

        .top-nav {
            position: fixed;
            top: 104px;
            right: clamp(14px, 3vw, 34px);
            display: flex;
            align-items: center;
            gap: 10px;
            z-index: 1050;
        }

        .currency-bar {
            min-height: 50px;
            color: var(--accent);
            padding: 10px 18px;
            border: 1px solid rgba(255, 250, 240, 0.2);
            border-radius: 8px;
            background: rgba(31, 37, 41, 0.86);
            box-shadow: 0 12px 28px rgba(31, 37, 41, 0.22);
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 20px;
            font-weight: 900;
        }

        .icon-btn {
            width: 52px;
            height: 52px;
            border: 0;
            border-radius: 8px;
            border-bottom: 4px solid var(--btn-shadow);
            color: white;
            background: linear-gradient(180deg, var(--btn-main) 0%, var(--btn-shadow) 100%);
            box-shadow: 0 12px 26px rgba(31, 37, 41, 0.2);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 25px;
            transition: transform 0.12s ease, filter 0.12s ease;
        }

        .icon-btn:hover,
        .btn:hover,
        .login-btn:hover,
        .mode-btn:hover {
            filter: brightness(1.05);
            transform: translateY(-1px);
        }

        .icon-btn:active,
        .btn:active,
        .login-btn:active {
            transform: translateY(3px);
            border-bottom-width: 1px;
        }

        .overlay {
            position: fixed;
            inset: 0;
            background: rgba(13, 18, 20, 0.72);
            backdrop-filter: blur(10px);
            display: none;
            z-index: 1400;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .modal-box {
            width: min(440px, calc(100vw - 28px));
            max-height: 85vh;
            overflow-y: auto;
            padding: 26px;
            border: 1px solid var(--line);
            border-radius: 8px;
            background: var(--panel-strong);
            box-shadow: 0 22px 70px rgba(0, 0, 0, 0.32);
            text-align: center;
        }

        .modal-title {
            color: var(--lb-text);
            margin: 0 0 16px;
            font-size: 1.4rem;
            font-weight: 900;
            text-transform: uppercase;
        }

        .shop-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            margin-top: 10px;
        }

        .shop-category-title {
            grid-column: 1 / -1;
            color: var(--lb-text);
            font-weight: 900;
            text-align: left;
            border-bottom: 2px solid var(--line);
            margin-top: 14px;
            padding-bottom: 7px;
            font-size: 0.88rem;
            text-transform: uppercase;
        }

        .shop-item {
            min-height: 170px;
            padding: 12px;
            border: 1px solid var(--line);
            border-radius: 8px;
            background: rgba(255, 255, 255, 0.72);
            box-shadow: 0 10px 22px rgba(31, 37, 41, 0.08);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: space-between;
            gap: 8px;
        }

        .skin-preview {
            width: 76px;
            height: 76px;
            border-radius: 8px;
            border: 1px solid var(--line);
            background-color: #fff;
            background-size: contain;
            background-repeat: no-repeat;
            background-position: center;
            position: relative;
        }

        .score-panel {
            width: min(560px, 100%);
            padding: 18px 22px;
            border: 1px solid rgba(255, 250, 240, 0.7);
            border-radius: 8px;
            background: var(--panel);
            box-shadow: 0 16px 42px rgba(31, 37, 41, 0.14);
            text-align: center;
        }

        .player-strip {
            color: var(--lb-text);
            font-size: 0.86rem;
            font-weight: 900;
            text-transform: uppercase;
        }

        .score-title {
            margin: 4px 0 0;
            color: var(--ink);
            font-size: clamp(2.2rem, 6vw, 3.9rem);
            font-weight: 950;
            line-height: 0.95;
        }

        .main-layout {
            display: grid;
            grid-template-columns: 432px minmax(250px, 300px);
            gap: 26px;
            align-items: start;
            width: min-content;
            max-width: 100%;
        }

        #game-board {
            width: 400px;
            height: 400px;
            padding: 10px;
            position: relative;
            overflow: hidden;
            border: 6px solid var(--board-border);
            border-radius: 8px;
            background:
                linear-gradient(135deg, rgba(255, 250, 240, 0.16), rgba(255, 250, 240, 0.02)),
                var(--board);
            box-shadow:
                inset 0 0 0 1px rgba(255, 250, 240, 0.18),
                0 18px 42px var(--board-shadow);
        }

        #game-board::before {
            content: "";
            position: absolute;
            inset: 10px;
            border-radius: 6px;
            background:
                linear-gradient(var(--line) 2px, transparent 2px) 0 0 / 100px 100px,
                linear-gradient(90deg, var(--line) 2px, transparent 2px) 0 0 / 100px 100px;
            pointer-events: none;
        }

        .leaderboard {
            width: 100%;
            min-height: 250px;
            padding: 20px;
            border: 1px solid var(--line);
            border-radius: 8px;
            background: var(--lb-bg);
            color: var(--lb-text);
            box-shadow: 0 16px 38px rgba(31, 37, 41, 0.13);
        }

        .leaderboard-title {
            margin: 0 0 12px;
            padding-bottom: 12px;
            border-bottom: 2px solid var(--line);
            color: var(--lb-text);
            text-align: center;
            font-size: 1rem;
            font-weight: 900;
            text-transform: uppercase;
        }

        .tile {
            width: 90px;
            height: 90px;
            color: var(--tile-text);
            position: absolute;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 8px;
            background-size: contain;
            background-repeat: no-repeat;
            background-position: center;
            filter: drop-shadow(0 10px 10px rgba(31, 37, 41, 0.18));
            font-size: 38px;
            font-weight: 950;
            text-shadow: 0 2px 0 var(--tile-glow), 0 0 10px rgba(255, 250, 240, 0.6);
            transition: transform 0.15s, filter 0.15s;
            z-index: 10;
        }

        .tile span {
            position: relative;
            z-index: 14;
            color: var(--number-color, var(--tile-text));
            background: rgba(255, 250, 240, 0.18);
            border-radius: 8px;
            padding: 2px 8px;
            text-shadow: 0 1px 0 rgba(0, 0, 0, 0.72), 0 0 8px rgba(0, 0, 0, 0.54), 0 0 14px var(--number-color, rgba(255, 255, 255, 0.9));
        }

        .tile-accessory,
        .tile-body {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-size: contain;
            background-repeat: no-repeat;
            background-position: center;
            pointer-events: none;
            z-index: 12;
        }

        .tile-body {
            z-index: 11;
        }

        .controls {
            display: grid;
            grid-template-areas: ". up ." "left down right";
            gap: 12px;
            justify-content: center;
            margin-top: 24px;
        }

        .btn {
            width: 72px;
            height: 72px;
            border: 0;
            border-bottom: 6px solid var(--btn-shadow);
            border-radius: 8px;
            color: white;
            background: linear-gradient(180deg, var(--btn-main) 0%, var(--btn-shadow) 100%);
            box-shadow: 0 12px 24px rgba(31, 37, 41, 0.16);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 30px;
            text-shadow: 0 2px 2px rgba(0, 0, 0, 0.28);
            transition: transform 0.12s ease, filter 0.12s ease;
        }

        #up { grid-area: up; }
        #left { grid-area: left; }
        #down { grid-area: down; }
        #right { grid-area: right; }

        .login-btn {
            width: 180px;
            height: 58px;
            margin: 10px auto;
            border: 0;
            border-bottom: 6px solid var(--btn-shadow);
            border-radius: 8px;
            color: white;
            background: linear-gradient(180deg, var(--btn-main) 0%, var(--btn-shadow) 100%);
            box-shadow: 0 12px 24px rgba(31, 37, 41, 0.18);
            cursor: pointer;
            display: block;
            font-size: 20px;
            font-weight: 900;
            transition: transform 0.12s ease, filter 0.12s ease;
        }

        .login-btn:disabled {
            opacity: 0.72;
            cursor: default;
            transform: none;
            border-bottom-width: 6px;
        }

        .mode-btn {
            width: 130px;
            height: 50px;
            border: 0;
            border-bottom: 4px solid rgba(31, 37, 41, 0.4);
            border-radius: 8px;
            color: white;
            background: rgba(31, 37, 41, 0.58);
            cursor: pointer;
            font-size: 16px;
            font-weight: 900;
            transition: transform 0.12s ease, filter 0.12s ease;
        }

        .mode-btn.active {
            color: #1f2529;
            background: linear-gradient(180deg, var(--accent) 0%, #f08f3c 100%);
            border-bottom-color: #ad6425;
        }

        #login-screen {
            position: fixed;
            inset: 0;
            padding: 24px;
            background:
                linear-gradient(135deg, rgba(239, 111, 79, 0.28) 0 20%, transparent 20%),
                linear-gradient(315deg, rgba(245, 184, 75, 0.24) 0 22%, transparent 22%),
                repeating-linear-gradient(90deg, rgba(255, 255, 255, 0.08) 0 1px, transparent 1px 36px),
                var(--board-border);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 2000;
            color: white;
            text-align: center;
        }

        #login-screen h1 {
            color: white;
            font-weight: 950;
            text-shadow: 0 6px 0 rgba(31, 37, 41, 0.22);
        }

        #account-name {
            border: 1px solid rgba(255, 250, 240, 0.76) !important;
            border-radius: 8px !important;
            background: rgba(255, 250, 240, 0.96) !important;
            color: var(--ink);
            box-shadow: 0 16px 36px rgba(31, 37, 41, 0.16);
            outline: 0;
            min-width: 280px;
            padding: 15px;
            margin-bottom: 15px;
            font-size: 18px;
            font-weight: 900;
        }

        .lock-overlay {
            width: 90px;
            height: 90px;
            position: absolute;
            border: 4px solid rgba(255, 250, 240, 0.28);
            border-radius: 8px;
            background: linear-gradient(145deg, #681e1e, #1c0808);
            box-shadow: inset 0 0 22px rgba(0, 0, 0, 0.4);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 42px;
            z-index: 50;
        }

        #game-over {
            position: absolute;
            inset: 0;
            display: none;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 100;
            border-radius: 6px;
            color: white;
            background: rgba(10, 13, 15, 0.88);
            backdrop-filter: blur(7px);
            text-align: center;
        }

        @@media (max-width: 920px) {
            .top-nav {
                position: static;
                justify-content: center;
                margin: 14px auto 0;
            }

            .merge-game-page {
                margin-top: 18px;
            }

            .main-layout {
                grid-template-columns: 1fr;
                justify-items: center;
                width: 100%;
            }

            .leaderboard {
                width: min(432px, 100%);
            }
        }

        @@media (max-width: 470px) {
            .merge-game-page {
                width: calc(100vw - 14px);
                align-items: stretch;
            }

            .score-panel {
                width: 100%;
            }

            .main-layout {
                overflow-x: auto;
                justify-items: start;
                padding-bottom: 8px;
            }

            .top-nav {
                width: calc(100vw - 16px);
            }

            .currency-bar {
                flex: 1;
                justify-content: center;
            }
        }
    </style>
</head>
<body>

    <div class="top-nav">
        <div class="currency-bar">🪙 <span id="coin-count">0</span></div>
        <button class="icon-btn" onclick="toggleModal('shop-overlay')">🛒</button>
        <button class="icon-btn" onclick="toggleModal('settings-overlay')">⚙️</button>
    </div>

    <div id="shop-overlay" class="overlay">
        <div class="modal-box">
            <h2 class="modal-title">CUSTOMIZATION SHOP</h2>
            <div id="shop-items-container"></div>
            <button class="login-btn" style="height: 45px; font-size: 16px; margin-top: 20px;" onclick="toggleModal('shop-overlay')">CLOSE</button>
        </div>
    </div>

    <div id="settings-overlay" class="overlay">
        <div class="modal-box">
            <h2 class="modal-title">THEMES</h2>
            <button class="login-btn" style="width: 100%;" onclick="changeTheme('original')">BREADED STICKS</button>
            <button class="login-btn" style="width: 100%;" onclick="changeTheme('ocean')">DEEP OCEAN</button>
            <button class="login-btn" style="width: 100%;" onclick="changeTheme('neon')">NEON MATRIX</button>
            <hr style="border: 1px solid var(--board-border); opacity: 0.3; margin: 20px 0;">
            <button class="login-btn" style="width: 150px; height: 45px; font-size: 16px;" onclick="toggleModal('settings-overlay')">CLOSE</button>
        </div>
    </div>

    <div id="login-screen">
        <h1 style="font-size: 55px; margin-bottom: 10px;">KALAPULK 2048</h1>
        <div id="account-name">@mergePlayerName</div>
        <div style="margin-bottom: 20px; display: flex; gap: 10px;">
            <button id="norm-btn" class="mode-btn active" onclick="setMode('normal')">NORMAL</button>
            <button id="hard-btn" class="mode-btn" onclick="setMode('hard')">HARD</button>
        </div>
        <button class="login-btn" onclick="startGame()">START</button>
    </div>

    <section class="merge-game-page">
    <div class="score-panel">
        <div class="player-strip">
            PLAYER: <span id="display-name">---</span> (<span id="display-mode">NORMAL</span>)
        </div>
        <h1 class="score-title">SCORE: <span id="current-score">0</span></h1>
    </div>

    <div class="main-layout">
        <div>
            <div id="game-board">
                <div id="game-over">
                    <h1 style="font-size: 40px;">GAME OVER</h1>
                    <button class="login-btn" style="width:140px;" onclick="restartGame()">RETRY</button>
                </div>
            </div>
            <div class="controls">
                <button class="btn" id="up" onclick="handleMove('up')">▲</button>
                <button class="btn" id="left" onclick="handleMove('left')">◀</button>
                <button class="btn" id="down" onclick="handleMove('down')">▼</button>
                <button class="btn" id="right" onclick="handleMove('right')">▶</button>
            </div>
        </div>

        <div class="leaderboard">
            <h3 class="leaderboard-title">HIGH SCORES</h3>
            <div id="leaderboard-list"></div>
        </div>
    </div>
    </section>

<script>
    let grid = Array(16).fill(null), score = 0, currentUser = "", gameMode = "normal", lockedIndex = -1, lockElement = null;
    let coins = 0, selectedTheme = "original", stateSaveTimer = null, coinSaveTimer = null, stateDirty = false;
    const accountName = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(mergePlayerName));
    
    const shopItems = {
        colour: [
            { id: 'stick', name: 'Fish Stick', price: 0, img: 'https://png.pngtree.com/png-vector/20240103/ourmid/pngtree-fish-stick-on-a-white-background-breaded-png-image_10938833.png' },
            { id: 'ice', name: 'Ice Stick', price: 25, img: 'ice-stick.png' },
            { id: 'spicy', name: 'Spicy Stick', price: 50, img: 'hot-stick.png' },
            { id: 'gold', name: 'Golden Stick', price: 1000, img: 'gold-stick.png' }
        ],
        head: [
            { id: 'head-none', name: 'None', price: 0, img: '' },
            { id: 'cat', name: 'Cat-Ears', price: 25, img: 'cat-pulk.png' },
            { id: 'tophat', name: 'tophat', price: 50, img: 'top-pulk.png' }
        ],
        body: [
            { id: 'body-none', name: 'None', price: 0, img: '' },
            { id: 'bow', name: 'bowtie', price: 10, img: 'bow-stick.png' },
             { id: 'donut', name: 'donut', price: 10, img: 'donut-pulk.png' }
           
        ]
    };

    let unlockedItems = ['stick', 'head-none', 'body-none'];
    let activeEquipment = { colour: 'stick', head: 'head-none', body: 'body-none' };
    const tileNumberStyles = {
        2: { color: '#00e5ff' },
        4: { color: '#7cff00' },
        8: { color: '#ffe600' },
        16: { color: '#ff9f1c' },
        32: { color: '#ff4d6d' },
        64: { color: '#ff2bd6' },
        128: { color: '#a855f7' },
        256: { color: '#38bdf8' },
        512: { color: '#22c55e' },
        1024: { color: '#facc15' },
        2048: { color: '#fb7185' }
    };

    function getTileNumberStyle(value) {
        const style = tileNumberStyles[value];
        if (style) return style;
        const hue = Math.round((Math.log2(value) * 47) % 360);
        return {
            color: `hsl(${hue}, 100%, 68%)`
        };
    }

    const board = document.getElementById('game-board'), scoreText = document.getElementById('current-score'), coinText = document.getElementById('coin-count');

    function toggleModal(id) {
        const el = document.getElementById(id);
        el.style.display = (el.style.display === 'flex') ? 'none' : 'flex';
        if (id === 'shop-overlay') updateShopUI();
    }

    function updateCurrency(amount) {
        coins += amount;
        coinText.innerText = coins;
        queueCoinSave();
    }
    updateCurrency(0);

    function updateShopUI() {
        const container = document.getElementById('shop-items-container');
        container.innerHTML = '';
        
        for(let category in shopItems) {
            const catTitle = document.createElement('div');
            catTitle.className = 'shop-category-title';
            catTitle.innerText = category.toUpperCase();
            container.appendChild(catTitle);
            
            const gridDiv = document.createElement('div');
            gridDiv.className = 'shop-grid';
            
            shopItems[category].forEach(item => {
                const isUnlocked = unlockedItems.includes(item.id);
                const isEquipped = activeEquipment[category] === item.id;
                
                gridDiv.innerHTML += `
                    <div class="shop-item">
                        <div class="skin-preview" style="background-image: url('${item.img}')">${item.id.includes('none') ? '❌' : ''}</div>
                        <div style="font-weight: bold; font-size: 14px;">${item.name}</div>
                        <button class="login-btn" style="width:100%; height:35px; font-size:14px; margin:0;" 
                            onclick="${isUnlocked ? `equipItem('${category}', '${item.id}')` : `buyItem('${category}', '${item.id}', ${item.price})`}"
                            ${isEquipped ? 'disabled' : ''}>
                            ${isEquipped ? 'EQUIPPED' : (isUnlocked ? 'SELECT' : '🪙 ' + item.price)}
                        </button>
                    </div>
                `;
            });
            container.appendChild(gridDiv);
        }
    }

    function buyItem(category, id, price) {
        if (coins >= price) {
            updateCurrency(-price);
            unlockedItems.push(id);
            queueStateSave();
            updateShopUI();
        } else { alert("Not enough coins!"); }
    }

    function equipItem(category, id) {
        activeEquipment[category] = id;
        queueStateSave();
        updateShopUI();
        refreshAllTiles();
    }

    function refreshAllTiles() {
        document.querySelectorAll('.tile').forEach(tile => {
            const colourItem = shopItems.colour.find(s => s.id === activeEquipment.colour);
            const headItem = shopItems.head.find(s => s.id === activeEquipment.head);
            const bodyItem = shopItems.body.find(s => s.id === activeEquipment.body);
            
            tile.style.backgroundImage = `url('${colourItem.img}')`;
            
            let headAcc = tile.querySelector('.tile-accessory');
            if(headAcc) headAcc.style.backgroundImage = (headItem && headItem.img) ? `url('${headItem.img}')` : 'none';

            let bodyAcc = tile.querySelector('.tile-body');
            if(bodyAcc) bodyAcc.style.backgroundImage = (bodyItem && bodyItem.img) ? `url('${bodyItem.img}')` : 'none';
        });
    }

    function changeTheme(theme) {
        document.body.className = ''; 
        if (theme !== 'original') document.body.classList.add('theme-' + theme);
        selectedTheme = theme;
        queueStateSave();
    }

    function setMode(m) { 
        gameMode = m; 
        document.getElementById('norm-btn').classList.toggle('active', m === 'normal');
        document.getElementById('hard-btn').classList.toggle('active', m === 'hard');
        document.getElementById('display-mode').innerText = m.toUpperCase();
    }

    async function loadPlayerState() {
        try {
            const response = await fetch('/Merge/State');
            if (!response.ok) {
                window.location.href = '/Accounts/Login';
                return false;
            }
            const state = await response.json();
            coins = state.coins || 0;
            unlockedItems = JSON.parse(state.unlockedItems || '["stick","head-none","body-none"]');
            activeEquipment = JSON.parse(state.activeEquipment || '{"colour":"stick","head":"head-none","body":"body-none"}');
            changeTheme(state.theme || "original");
            coinText.innerText = coins;
            return true;
        } catch {
            coins = 0;
            unlockedItems = ['stick', 'head-none', 'body-none'];
            activeEquipment = { colour: 'stick', head: 'head-none', body: 'body-none' };
            selectedTheme = "original";
            coinText.innerText = coins;
            return true;
        }
    }

    function queueStateSave() {
        if (!currentUser) return;
        stateDirty = true;
        clearTimeout(stateSaveTimer);
        stateSaveTimer = setTimeout(savePlayerState, 150);
    }

    function queueCoinSave() {
        if (!currentUser) return;
        clearTimeout(coinSaveTimer);
        coinSaveTimer = setTimeout(saveCoins, 150);
    }

    function postMergeJson(url, data, keepAlive = false) {
        const body = JSON.stringify(data);

        if (keepAlive && navigator.sendBeacon) {
            navigator.sendBeacon(url, new Blob([body], { type: 'application/json' }));
            return null;
        }

        return fetch(url, {
            method: 'POST',
            keepalive: keepAlive,
            headers: { 'Content-Type': 'application/json' },
            body
        });
    }

    async function savePlayerState(keepAlive = false) {
        if (!currentUser) return;
        clearTimeout(stateSaveTimer);
        stateSaveTimer = null;
        try {
            const request = postMergeJson('/Merge/State', {
                coins,
                unlockedItems: JSON.stringify(unlockedItems),
                activeEquipment: JSON.stringify(activeEquipment),
                theme: selectedTheme
            }, keepAlive);
            if (request && !keepAlive) await request;
            stateDirty = false;
        } catch {
        }
    }

    async function saveCoins(keepAlive = false) {
        if (!currentUser) return;
        clearTimeout(coinSaveTimer);
        coinSaveTimer = null;
        try {
            const request = postMergeJson('/Merge/Coins', { coins }, keepAlive);
            if (request && !keepAlive) await request;
        } catch {
        }
    }

    function saveBeforeLeaving() {
        if (stateDirty) savePlayerState(true);
        saveCoins(true);
    }

    async function startGame() {
        currentUser = accountName || "Player";
        document.getElementById('display-name').innerText = currentUser;
        if (!await loadPlayerState()) return;
        document.getElementById('login-screen').style.display = 'none';
        await updateLeaderboard();
        addRandomTile(); addRandomTile();
        if (gameMode === 'hard') updateLock();
    }

    function applyTileNumberColor(t) {
        const style = getTileNumberStyle(t.value);
        t.element.style.setProperty('--number-color', style.color);
    }

    
    function createTile(v, i) {
        const t = { value: v, element: document.createElement('div') };
        t.element.className = 'tile';
        
        const valSpan = document.createElement('span');
        valSpan.innerText = v;
        t.element.appendChild(valSpan);

        const bdy = document.createElement('div');
        bdy.className = 'tile-body';
        t.element.appendChild(bdy);
        
        const acc = document.createElement('div');
        acc.className = 'tile-accessory';
        t.element.appendChild(acc);

        board.appendChild(t.element);
        updatePosition(t, i);
        
        const colourItem = shopItems.colour.find(s => s.id === activeEquipment.colour);
        const headItem = shopItems.head.find(s => s.id === activeEquipment.head);
        const bodyItem = shopItems.body.find(s => s.id === activeEquipment.body);

        t.element.style.backgroundImage = `url('${colourItem.img}')`;
        acc.style.backgroundImage = (headItem && headItem.img) ? `url('${headItem.img}')` : 'none';
        bdy.style.backgroundImage = (bodyItem && bodyItem.img) ? `url('${bodyItem.img}')` : 'none';
        applyTileNumberColor(t);

        return t;
    }

    function slideAndMerge(rowIndices) {
        let changed = false, newRow = Array(4).fill(null);
        for (let i = 0; i < 4; i++) {
            let tile = grid[rowIndices[i]];
            if (!tile) continue;
            let targetIdx = i;
            for (let j = i - 1; j >= 0; j--) {
                if ((gameMode === 'hard' && rowIndices[j] === lockedIndex) || newRow[j] !== null) {
                    targetIdx = j + 1; break;
                }
                targetIdx = j;
            }
            if (targetIdx > 0 && newRow[targetIdx-1] && newRow[targetIdx-1].value === tile.value) {
                newRow[targetIdx-1].value *= 2;
                score += newRow[targetIdx-1].value;
                updateCurrency(Math.floor(newRow[targetIdx-1].value / 10)); 
                scoreText.innerText = score;
                tile.element.remove();
                
                newRow[targetIdx-1].element.querySelector('span').innerText = newRow[targetIdx-1].value;
                applyTileNumberColor(newRow[targetIdx-1]);
                
                changed = true;
            } else {
                newRow[targetIdx] = tile;
                if (targetIdx !== i) changed = true;
            }
        }
        return { newRow, changed };
    }
    

    function updatePosition(t, i) {
        let r = Math.floor(i / 4), c = i % 4;
        t.element.style.transform = `translate(${c * 100 + 10}px, ${r * 100 + 10}px)`;
    }

    function updateLock() {
        if (lockElement) lockElement.remove();
        let slots = grid.map((v, i) => v === null ? i : null).filter(v => v !== null);
        if (slots.length > 0) {
            lockedIndex = slots[Math.floor(Math.random() * slots.length)];
            lockElement = document.createElement('div');
            lockElement.className = 'lock-overlay'; lockElement.innerHTML = '🔒';
            let r = Math.floor(lockedIndex/4), c = lockedIndex%4;
            lockElement.style.transform = `translate(${c * 100 + 10}px, ${r * 100 + 10}px)`;
            board.appendChild(lockElement);
        }
    }

    function handleMove(dir) {
        let anyChanged = false;
        for (let i = 0; i < 4; i++) {
            let indices = [];
            for (let j = 0; j < 4; j++) {
                if (dir === 'left' || dir === 'right') indices.push(i * 4 + j);
                else indices.push(j * 4 + i);
            }
            if (dir === 'right' || dir === 'down') indices.reverse();
            let res = slideAndMerge(indices);
            indices.forEach((idx, k) => {
                grid[idx] = res.newRow[k];
                if (grid[idx]) updatePosition(grid[idx], idx);
            });
            if (res.changed) anyChanged = true;
        }
        if (anyChanged) {
            setTimeout(() => { 
                addRandomTile(); 
                if (gameMode === 'hard') updateLock();
                if (checkGameOver()) endGame();
            }, 100);
        }
    }

    function checkGameOver() {
        if (grid.filter((t, i) => t === null && i !== lockedIndex).length > 0) return false;
        for (let i = 0; i < 4; i++) {
            for (let j = 0; j < 4; j++) {
                let idx = i * 4 + j; if (!grid[idx]) continue;
                if (j < 3 && grid[idx + 1] && grid[idx + 1].value === grid[idx].value) return false;
                if (i < 3 && grid[idx + 4] && grid[idx + 4].value === grid[idx].value) return false;
            }
        }
        return true;
    }

    async function endGame() {
        await saveScore(score);
        document.getElementById('game-over').style.display = 'flex';
        await updateLeaderboard();
    }

 
    async function saveScore(s) {
        try {
            await fetch('/Merge/Score', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ score: s, mode: gameMode })
            });
        } catch {
        }
    }

    async function updateLeaderboard() {
        let h = [];
        try {
            const response = await fetch('/Merge/Leaderboard');
            h = await response.json();
        } catch {
            h = [];
        }
        document.getElementById('leaderboard-list').innerHTML = h.map(s => `
            <div style="display:flex; justify-content:space-between; padding:8px 0; border-bottom:1px solid rgba(0,0,0,0.1);">
                <span>${s.name}</span>
                <b>${s.score}</b>
            </div>`).join('');
    }

    function addRandomTile() {
        let slots = grid.map((v, i) => (v === null && i !== lockedIndex) ? i : null).filter(v => v !== null);
        if (slots.length > 0) {
            let spot = slots[Math.floor(Math.random() * slots.length)];
            grid[spot] = createTile(2, spot);
        }
    }

    function restartGame() {
        grid.forEach(t => t && t.element.remove());
        grid = Array(16).fill(null); if (lockElement) lockElement.remove();
        score = 0; scoreText.innerText = "0";
        document.getElementById('game-over').style.display = 'none';
        addRandomTile(); addRandomTile(); if (gameMode === 'hard') updateLock();
    }

    window.addEventListener('keydown', (e) => {
        const keys = { "ArrowLeft": "left", "ArrowRight": "right", "ArrowUp": "up", "ArrowDown": "down" };
        if (keys[e.key]) { e.preventDefault(); handleMove(keys[e.key]); }
    });

    window.addEventListener('pagehide', saveBeforeLeaving);
    window.addEventListener('beforeunload', saveBeforeLeaving);
    document.addEventListener('visibilitychange', () => {
        if (document.visibilityState === 'hidden') saveBeforeLeaving();
    });
</script>
</body>
</html>
