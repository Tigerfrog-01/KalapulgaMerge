@model IEnumerable<KalapulgaMerge.Models.Case.CaseIndexViewModel>

@{
    ViewData["Title"] = "Juhtumid";
    int rowNumber = 1;
}

<div class="container py-4" style="font-family: sans-serif;">
    <div>
        <a asp-action="Create" asp-controller="Case" class="btn btn-primary">Lisa Juhtum</a>
    </div>

    <div class="h1 my-3">Juhtumid</div>

    <table class="table table-hover">
        <thead>
            <tr>
                <th scope="col">#</th>
                <th scope="col">Juhtumi ID</th>
                <th scope="col">Kasutaja ID</th>
                <th scope="col">Kirjeldus</th>
                <th scope="col">Staatus</th>
                <th scope="col">Tööriistad</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@rowNumber</td>
                    <td>@item.CaseID.ToString().Substring(0, 8)...</td>
                    <td>@item.UserID</td>
                    <td>@item.Description</td>
                    <td>@item.CurrentCaseStatus</td>
                    <td>
                        <a asp-action="Edit" asp-controller="Case" asp-route-id="@item.CaseID" class="btn btn-primary btn-sm">Uuenda</a>
                        <a asp-action="Delete" asp-controller="Case" asp-route-id="@item.CaseID" class="btn btn-outline-danger btn-sm">Eemalda</a>
                    </td>
                </tr>
                rowNumber += 1;
            }
        </tbody>
    </table>
</div>